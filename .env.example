# Required — password for the code-server browser login.
# Use a strong, random value. Rotate periodically.
PASSWORD=change-me-to-something-strong

# Optional — hashed password (argon2id). If set, takes precedence over PASSWORD.
# Generate with:  echo -n "your-password" | argon2 "$(openssl rand -hex 8)" -e
# HASHED_PASSWORD=

# Optional — sudo password inside the container. If unset, sudo is passwordless
# (recommended for a dev environment; the real security boundary is the container).
# SUDO_PASSWORD=

# Timezone inside the container.
TZ=America/New_York

# Optional — extra args appended to the code-server invocation.
# Example: --disable-update-check
# CODE_SERVER_ARGS=

# NVIDIA runtime — set by docker-compose or the Kubernetes deployment, not by users.
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,utility
