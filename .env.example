# Required — password for the code-server browser login.
# Use a strong, random value. Rotate periodically.
PASSWORD=change-me-to-something-strong

# Optional — hashed password (argon2id). If set, takes precedence over PASSWORD.
# Generate with:  echo -n "your-password" | argon2 "$(openssl rand -hex 8)" -e
# HASHED_PASSWORD=

# Optional — sudo password inside the container. If unset, sudo is passwordless
# (recommended for a dev environment; the real security boundary is the container).
# SUDO_PASSWORD=

# Timezone inside the container.
TZ=America/New_York

# Optional — extra args appended to the code-server invocation.
# Example: --disable-update-check
# CODE_SERVER_ARGS=

# NVIDIA runtime — set by docker-compose or the Kubernetes deployment, not by users.
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,utility

# --- Remote-SSH (optional) --------------------------------------------------
# Lets VS Code Desktop / Cursor / Windsurf connect natively via the Remote-SSH
# extension. Off by default. See docs/remote-ssh.md for the full walk-through.
# ENABLE_SSHD=true

# Port sshd listens on inside the container. Default 2222.
# SSH_PORT=2222

# Your SSH public key(s). For multiple keys in compose, use a YAML block
# scalar; in .env files, put one key per SSH_AUTHORIZED_KEYS= line and rely
# on a compose override, or edit ~/.ssh/authorized_keys after first boot.
# Keys are merged into authorized_keys on every boot (idempotent).
# SSH_AUTHORIZED_KEYS="ssh-ed25519 AAAAC3Nz... you@laptop"
